# Ably API key (Account → App → API Keys). Needs the Push Admin capability.
# The APNs auth key (.p8) is uploaded to the Ably app's Push settings, so this
# server authenticates to Ably only — it no longer signs APNs requests itself.
#
# OPTIONAL: if left unset, the server auto-creates an ephemeral Ably *sandbox*
# app on startup (endpoint nonprod:sandbox) and configures its APNS credentials
# from the APPLE_* vars + .p8 below. In that case the APPLE_* vars are required.
ABLY_API_KEY=your_app.key_id:key_secret

# Apple Developer credentials.
# Used to configure APNS on the auto-created sandbox app (and by the legacy
# apns.js helper). Find these at: https://developer.apple.com/account

# 10-character Team ID from your Apple Developer account
APPLE_TEAM_ID=XXXXXXXXXX

# Key ID from the .p8 file you downloaded
APPLE_KEY_ID=XXXXXXXXXX

# Your app's bundle identifier
APPLE_BUNDLE_ID=com.example.LiveActivityExample

# Path to your .p8 private key file (relative to server/ directory)
APPLE_KEY_PATH=./AuthKey_XXXXXXXXXX.p8

# 'sandbox' for development/TestFlight, 'production' for App Store
APNS_ENV=sandbox

# Port for the dashboard web server
PORT=3000
